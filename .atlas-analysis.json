  "keyFeatures": [
    "Permissioned blockchain with known participant identities",
    "Modular pluggable consensus (Raft CFT and SmartBFT)",
    "Smart contracts (chaincode) in Go, Java, and Node.js",
    "Execute-order-validate transaction model for performance and scalability",
    "Channel-based privacy and private data collections",
    "Membership Service Provider (MSP) for identity management",
    "Fabric Gateway for simplified client application development",
    "Operations service for health monitoring and metrics"
  ],
  "publicApiSurface": [
    "peer node start",
    "peer lifecycle chaincode install/approve/commit",
    "peer channel create/join/fetch",
    "peer chaincode invoke/query",
    "configtxgen -outputBlock/-outputCreateChannelTx",
    "configtxlator proto_encode/proto_decode/compute_update",
    "cryptogen generate/showtemplate",
    "osnadmin channel join/list/remove",
    "ledgerutil compare/identifytxs",
    "Fabric Gateway gRPC service (Endorse/Submit/CommitStatus/ChaincodeEvents)",
    "Operations REST API (/healthz, /metrics, /logspec, /version)"
  ]
}
